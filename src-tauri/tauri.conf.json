{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "拾阶",
  "version": "1.2.3",
  "identifier": "com.myworld.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "拾阶",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "offlineInstaller",
        "silent": true
      }
    },
    "resources": {
      "target/release/WebView2Loader.dll": "WebView2Loader.dll"
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
